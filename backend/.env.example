# Servidor
PORT=3000
NODE_ENV=development

# CORS: coloque o domínio do Netlify em produção.
# Exemplo: https://meu-validador.netlify.app
FRONTEND_ORIGIN=http://localhost:8080

# Admin: troque antes do deploy.
ADMIN_TOKEN=troque-este-token-admin

# Cache
CACHE_TTL_DAYS=60
DATA_DIR=./data

# Rate limit público
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Provider Binlist
BINLIST_ENABLED=true
BINLIST_TIMEOUT_MS=4500

# Provider customizado/autorizado.
# Use um provedor que você tenha direito de usar.
# Exemplo de template: https://api.exemplo.com/bin/{bin}
CUSTOM_BIN_API_ENABLED=false
CUSTOM_BIN_API_NAME=custom
CUSTOM_BIN_API_URL_TEMPLATE=
CUSTOM_BIN_API_KEY=
CUSTOM_BIN_API_KEY_HEADER=Authorization
CUSTOM_BIN_API_TIMEOUT_MS=5000
